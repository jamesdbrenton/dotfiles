IdentitiesOnly yes

# Linux-specific performance and keep-alive settings
# Need mkdir -p ~/.ssh/sockets
{{- if eq .chezmoi.os "linux" }}
Host *
    # Keep the connection alive
    ServerAliveInterval 60
    ServerAliveCountMax 3
    TCPKeepAlive yes

    # Optimum Neovim/SCP Multiplexing
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h:%p
    ControlPersist 10m
{{- end }}

{{- if eq .chezmoi.os "windows" }}
Host *
    # Keeps the SCP connection from timing out while you type
    ServerAliveInterval 30
    ServerAliveCountMax 5
    
    # Compress the data streams (speeds up file reads/writes over netrw)
    Compression yes
{{- end }}

# Universal settings for all machines
